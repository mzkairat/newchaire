{
          "version": 2,
          "builds": [
                      { "src": "public/**", "use": "@vercel/static" },
                      { "src": "api/order.js", "use": "@vercel/node" }
          ],
          "routes": [
                      { "src": "/api/order", "dest": "/api/order.js" },
                      { "src": "/", "dest": "/public/index.html" },
                      { "src": "/(.*)", "dest": "/public/$1" }
          ]
}
